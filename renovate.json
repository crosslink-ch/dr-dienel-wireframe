{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Zagreb",
  "schedule": [
    "before 10am on Monday"
  ],
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "rangeStrategy": "pin",
  "automerge": true,
  "automergeType": "branch",
  "ignoreTests": true,
  "major": {
    "enabled": false
  },
  "packageRules": [
    {
      "groupName": "Payload CMS",
      "matchPackageNames": [
        "@payloadcms/**",
        "payload"
      ]
    },
    {
      "groupName": "React",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ]
    },
    {
      "groupName": "Playwright",
      "matchPackageNames": [
        "playwright",
        "playwright-core",
        "@playwright/**"
      ]
    },
    {
      "groupName": "Radix UI",
      "matchPackageNames": [
        "@radix-ui/**"
      ]
    },
    {
      "groupName": "Tailwind CSS",
      "matchPackageNames": [
        "tailwindcss",
        "@tailwindcss/**"
      ]
    }
  ]
}
